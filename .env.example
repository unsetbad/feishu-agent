# LLM API 配置（优先使用 LLM_*，兼容 OPENAI_*）
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
LLM_API_KEY=replace-with-your-key
LLM_MODEL=mimo-v2.5-pro

# 兼容旧变量名（如果设置了 LLM_* 则忽略以下变量）
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=replace-with-your-key
# OPENAI_MODEL=gpt-4o-mini

# Agent 行为
AGENT_SYSTEM_PROMPT=你是一个在飞书里工作的 AI 助手。回答要简洁、准确、可执行，默认使用中文。
AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=1200

# 飞书回复
FEISHU_REPLY_MAX_CHARS=4000
FEISHU_REPLY_IN_THREAD=false

# 事件处理
FEISHU_EVENT_DEDUP_TTL_SECONDS=3600
FEISHU_RESTART_DELAY_SECONDS=5
FEISHU_IGNORE_SENDER_IDS=
